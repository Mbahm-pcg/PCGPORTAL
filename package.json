{
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@neondatabase/serverless": "^1.1.0",
    "@netlify/blobs": "^10.7.2",
    "@netlify/database": "^1.0.0",
    "drizzle-orm": "^1.0.0-beta.22",
    "googleapis": "^149.0.0",
    "minimalistic-assert": "^1.0.1",
    "nodemailer": "^9.0.1",
    "pdf-parse": "^1.1.4",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7"
  },
  "scripts": {
    "test": "node --test 'netlify/functions/analyst-lib/*.test.mjs' 'src/*.test.mjs' 'netlify/functions/deal-lib/*.test.js' 'netlify/functions/ndcp-lib/*.test.js' 'netlify/functions/auth-lib/*.test.js' 'netlify/functions/audit-lib/*.test.js'",
    "build": "esbuild app.jsx --bundle --outfile=app.js --jsx=transform --platform=browser",
    "watch": "esbuild app.jsx --bundle --outfile=app.js --jsx=transform --platform=browser --watch",
    "build:src": "esbuild src/main.jsx --bundle --outfile=app.js --jsx=transform --platform=browser",
    "watch:src": "esbuild src/main.jsx --bundle --outfile=app.js --jsx=transform --platform=browser --watch",
    "build:babel": "babel app.jsx -o app.js --presets @babel/preset-react"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "drizzle-kit": "^1.0.0-beta.22",
    "esbuild": "^0.28.0"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-trace-base": "2.8.0",
    "@opentelemetry/sdk-trace-node": "2.8.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.0": true
  }
}
